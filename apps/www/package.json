{
  "name": "shadcn-chat",
  "version": "0.1.0",
  "description": "trueChats desktop app",
  "author": "trueosdev",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:web:ensure\" \"npm:dev:electron\"",
    "dev:web": "next dev",
    "dev:web:ensure": "sh -c 'if npx wait-on tcp:3000 --timeout 1000; then echo \"[dev:web] Reusing existing Next server on :3000\"; else npm run dev:web; fi'",
    "dev:electron": "wait-on tcp:3000 && electron electron/main.js",
    "icons:generate": "bash electron/icons/generate-icons.sh electron/icons/icon-source.png 8",
    "build": "next build",
    "dist": "npm run build && electron-builder --publish never",
    "release": "npm run build && electron-builder --publish always",
    "start": "next start",
    "lint": "next lint",
    "check-types": "tsc --noEmit"
  },
  "build": {
    "appId": "dev.trueos.chats.desktop",
    "productName": "trueChats",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "trueosdev",
        "repo": "trueChat"
      }
    ],
    "electronVersion": "37.4.0",
    "mac": {
      "icon": "electron/icons/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "trueChats uses the microphone for voice and video calls.",
        "NSCameraUsageDescription": "trueChats uses the camera for video calls.",
        "NSScreenCaptureUsageDescription": "trueChats needs screen recording permission to share your screen on calls."
      }
    },
    "win": {
      "icon": "electron/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "electron/icons/icon.png",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@emoji-mart/data": "^1.1.2",
    "@emoji-mart/react": "^1.1.1",
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@shadcn-chat/ui": "^1.0.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.84.0",
    "@swc/helpers": "^0.5.11",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "emoji-mart": "^5.5.2",
    "framer-motion": "^10.18.0",
    "geist": "^1.2.1",
    "livekit-client": "^2.18.0",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^1.7.0",
    "next": "^16.0.7",
    "next-themes": "^0.3.0",
    "electron-updater": "^6.6.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-image-crop": "^11.0.10",
    "react-resizable-panels": "^4.8.0",
    "styled-jsx": "^5.1.6",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "37.4.0",
    "electron-builder": "^26.0.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-image-crop": "^8.1.6",
    "autoprefixer": "^10.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  }
}
